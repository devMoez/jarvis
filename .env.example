# Copy this file to .env and fill in your keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=
OPENROUTER_API_KEY_4=

# Telegram remote control (optional)
# 1. Message @BotFather on Telegram → /newbot → paste token below
# 2. Get your numeric user ID from @userinfobot → paste below
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_ID=

# Hugging Face (optional, suppresses rate-limit warnings for local embeddings/wakewords)
HF_TOKEN=
